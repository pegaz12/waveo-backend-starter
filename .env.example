PORT=8080
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-base44-app.example

# Teltonika RMS
RMS_BASE_URL=https://rms.teltonika-networks.com
RMS_API_TOKEN=replace_me

# Optional: set the exact RMS paths if your tenant / API version differs.
RMS_DEVICES_PATH=/api/devices
RMS_DEVICE_STATUS_PATH_TEMPLATE=/api/devices/:id/status
RMS_DEVICE_CLIENTS_PATH_TEMPLATE=/api/devices/:id/clients
RMS_DEVICE_USAGE_PATH_TEMPLATE=/api/devices/:id/usage/today
